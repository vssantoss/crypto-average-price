{
  "name": "crypto-average-price-desktop",
  "private": true,
  "version": "0.0.0",
  "description": "Desktop packaging wrapper for Crypto Average Price.",
  "main": "electron/main.cjs",
  "scripts": {
    "start": "node scripts/start-dev.mjs",
    "install:web": "pnpm --dir crypto-average-price install --frozen-lockfile",
    "build:web": "pnpm run install:web && pnpm --dir crypto-average-price build",
    "electron:dev": "pnpm run install:web && node scripts/electron-dev.mjs",
    "electron:dist": "pnpm run build:web && electron-builder --publish never",
    "electron:dist:win": "pnpm run build:web && electron-builder --win --publish never",
    "electron:dist:mac": "pnpm run build:web && electron-builder --mac --publish never",
    "electron:dist:linux": "pnpm run build:web && electron-builder --linux --publish never"
  },
  "packageManager": "pnpm@11.1.3+sha512.c85357fe17ca12dd23dd7071822666dfd7e3cb76fe214e3370b5ea2fb34f2a231185509b63e717f3cd0acb38dd3f8d82bcd5e8172400ae678b70ea4fbed0896d",
  "devDependencies": {
    "electron": "^41.7.1",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.cryptoaverageprice.app",
    "productName": "Crypto Average Price",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "crypto-average-price/dist/**/*",
      "package.json"
    ],
    "win": {
      "target": "zip"
    },
    "mac": {
      "identity": null,
      "target": "zip"
    },
    "linux": {
      "target": "tar.gz"
    }
  }
}
